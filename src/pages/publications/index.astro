---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const articles = [
  {
    category: "Legal Analysis",
    title: "Understanding Procedural Fairness in Indonesian Civil Litigation",
    author: "Ahmad Pratama",
    readTime: "8 min read",
    color: "egyptian",
    date: "2024-12-15"
  },
  {
    category: "Moot Court Guide",
    title: "Mastering Oral Advocacy: Tips from Competition Veterans",
    author: "Sarah Indonesia",
    readTime: "6 min read",
    color: "mauve",
    date: "2024-11-20"
  },
  {
    category: "Research Paper",
    title: "The Evolution of Criminal Procedure Code in Indonesia",
    author: "Budi Santoso",
    readTime: "12 min read",
    color: "canary",
    date: "2023-08-10"
  },
  {
    category: "Case Study",
    title: "Landmark Supreme Court Rulings: A Comprehensive Review",
    author: "Diana Chen",
    readTime: "10 min read",
    color: "vanilla",
    date: "2023-05-22"
  },
  {
    category: "Legal Analysis",
    title: "Digital Evidence Admissibility in Indonesian Courts",
    author: "Michael Wong",
    readTime: "7 min read",
    color: "egyptian",
    date: "2024-10-05"
  },
  {
    category: "Moot Court Guide",
    title: "Building Strong Legal Arguments: A Systematic Approach",
    author: "Lisa Hartono",
    readTime: "5 min read",
    color: "mauve",
    date: "2024-09-18"
  },
  {
    category: "Research Paper",
    title: "Alternative Dispute Resolution in Commercial Disputes",
    author: "Robert Kim",
    readTime: "15 min read",
    color: "canary",
    date: "2024-08-22"
  },
  {
    category: "Case Study",
    title: "Analysis of Recent Constitutional Court Decisions",
    author: "Amira Putri",
    readTime: "9 min read",
    color: "vanilla",
    date: "2024-07-14"
  },
  {
    category: "Legal Analysis",
    title: "Corporate Liability in Environmental Law Violations",
    author: "Kevin Susanto",
    readTime: "11 min read",
    color: "egyptian",
    date: "2024-06-30"
  },
  {
    category: "Moot Court Guide",
    title: "Cross-Examination Techniques That Work",
    author: "Rachel Indonesia",
    readTime: "8 min read",
    color: "mauve",
    date: "2024-05-25"
  },
  {
    category: "Research Paper",
    title: "Comparative Study: Indonesian vs. Common Law Systems",
    author: "David Chen",
    readTime: "20 min read",
    color: "canary",
    date: "2024-04-12"
  },
  {
    category: "Case Study",
    title: "Intellectual Property Disputes in the Digital Age",
    author: "Siti Nurhaliza",
    readTime: "7 min read",
    color: "vanilla",
    date: "2024-03-08"
  },
  {
    category: "Legal Analysis",
    title: "Employment Law Updates: What New Graduates Should Know",
    author: "Antoni Wijaya",
    readTime: "6 min read",
    color: "egyptian",
    date: "2024-02-14"
  },
  {
    category: "Moot Court Guide",
    title: "Writing Persuasive Memoranda: Best Practices",
    author: "Maria Gunawan",
    readTime: "4 min read",
    color: "mauve",
    date: "2024-01-28"
  },
  {
    category: "Research Paper",
    title: "Tax Dispute Resolution Mechanisms in Indonesia",
    author: "Hendra Rusli",
    readTime: "14 min read",
    color: "canary",
    date: "2023-12-10"
  },
  {
    category: "Case Study",
    title: "Bankruptcy proceedings Analysis: Recent Developments",
    author: "Nina Kartika",
    readTime: "8 min read",
    color: "vanilla",
    date: "2023-11-05"
  },
  {
    category: "Legal Analysis",
    title: "Human Rights Compliance in Business Operations",
    author: "Felix Tanoto",
    readTime: "9 min read",
    color: "egyptian",
    date: "2023-10-20"
  },
  {
    category: "Moot Court Guide",
    title: "Handling Expert Witnesses Effectively",
    author: "Yuni Larasati",
    readTime: "6 min read",
    color: "mauve",
    date: "2023-09-15"
  },
  {
    category: "Research Paper",
    title: "Foreign Investment Legal Framework in Indonesia",
    author: "Bowo Prasetyo",
    readTime: "18 min read",
    color: "canary",
    date: "2023-08-01"
  },
  {
    category: "Case Study",
    title: "Mediation Success Stories from Indonesian Courts",
    author: "Rina Susilowati",
    readTime: "5 min read",
    color: "vanilla",
    date: "2023-07-12"
  }
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const ITEMS_PER_PAGE = 10;
---

<Layout>
  <Header />
  
  <main class="pt-24 pb-20 bg-cornsilk">
    <!-- Page Header -->
    <section class="py-12 bg-vanilla/30 relative overflow-hidden">
      <!-- Background Elements -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-canary/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-mauve/10 rounded-full blur-3xl"></div>

      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-cornsilk rounded-full mb-4">
          <span class="w-1.5 h-1.5 bg-mauve rounded-full"></span>
          <span class="text-mauve font-medium text-sm">Knowledge Sharing</span>
        </div>
        
        <h1 class="fluid-h2 font-bold text-egyptian mb-4">
          <span class="font-script text-5xl md:text-6xl text-mauve">P</span>ublications
        </h1>
        
        <p class="text-egyptian/70 max-w-xl mx-auto fluid-body">
          Browse our collection of legal insights, research, and analysis.
        </p>
      </div>
    </section>

    <!-- Search and Sort -->
    <section class="py-6 -mt-4">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row gap-4 items-center justify-between">
          <!-- Search -->
          <div class="relative w-full sm:w-80">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-egyptian/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input 
              type="text" 
              id="search-input"
              placeholder="Search publications..." 
              class="w-full pl-10 pr-4 py-3 bg-white border border-egyptian/10 rounded-xl text-egyptian placeholder-egyptian/40 focus:outline-none focus:border-egyptian/30 focus:ring-2 focus:ring-egyptian/10 transition-all"
            />
          </div>
          
          <!-- Sort -->
          <div class="flex items-center gap-2">
            <span class="text-sm text-egyptian/60">Sort by:</span>
            <select 
              id="sort-select"
              class="px-4 py-3 bg-white border border-egyptian/10 rounded-xl text-egyptian text-sm focus:outline-none focus:border-egyptian/30 cursor-pointer"
            >
              <option value="date-desc">Newest First</option>
              <option value="date-asc">Oldest First</option>
              <option value="title-asc">Title A-Z</option>
              <option value="title-desc">Title Z-A</option>
            </select>
          </div>
        </div>
      </div>
    </section>

    <!-- File Organizer Table -->
    <section class="py-4">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-2xl border border-egyptian/10 overflow-hidden">
          <!-- Table Header -->
          <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-3 bg-egyptian/5 border-b border-egyptian/10 text-sm font-semibold text-egyptian/60">
            <div class="col-span-6">Title</div>
            <div class="col-span-2">Category</div>
            <div class="col-span-2">Date</div>
            <div class="col-span-2">Author</div>
          </div>

          <!-- Table Body -->
          <div id="articles-list">
            {articles.slice(0, ITEMS_PER_PAGE).map((article, index) => (
              <a 
                href="#" 
                class="block md:grid md:grid-cols-12 gap-4 px-6 py-4 border-b border-egyptian/5 hover:bg-vanilla/20 transition-colors group"
                data-title={article.title.toLowerCase()}
                data-category={article.category.toLowerCase()}
                data-author={article.author.toLowerCase()}
                data-date={article.date}
              >
                <div class="col-span-6 flex items-start gap-3">
                  <svg class="w-5 h-5 text-egyptian/40 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  <span class="font-medium text-egyptian group-hover:text-mauve transition-colors line-clamp-2">
                    {article.title}
                  </span>
                </div>
                <div class="col-span-2 md:col-span-2 mt-2 md:mt-0">
                  <span class={`inline-block px-2 py-1 text-xs font-semibold rounded-full ${
                    article.color === 'egyptian' ? 'bg-egyptian/10 text-egyptian' :
                    article.color === 'mauve' ? 'bg-mauve/10 text-mauve' :
                    article.color === 'canary' ? 'bg-canary/30 text-egyptian' :
                    'bg-vanilla text-egyptian/70'
                  }`}>
                    {article.category}
                  </span>
                </div>
                <div class="col-span-2 md:col-span-2 mt-2 md:mt-0 text-sm text-egyptian/50">
                  {new Date(article.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </div>
                <div class="col-span-2 md:col-span-2 mt-2 md:mt-0 text-sm text-egyptian/50 flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  {article.author}
                </div>
              </a>
            ))}
          </div>

          <!-- No Results -->
          <div id="no-results" class="hidden py-12 text-center text-egyptian/50">
            <svg class="w-12 h-12 mx-auto mb-4 text-egyptian/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p>No publications found</p>
          </div>
        </div>

        <!-- Pagination -->
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-6">
          <p id="pagination-info" class="text-sm text-egyptian/50">
            Showing 1-{Math.min(ITEMS_PER_PAGE, articles.length)} of {articles.length}
          </p>
          
          <div class="flex items-center gap-2">
            <button 
              id="prev-btn"
              class="px-4 py-2 bg-white border border-egyptian/10 rounded-lg text-sm text-egyptian/50 cursor-not-allowed"
              disabled
            >
              ‹ Prev
            </button>
            
            <div id="page-numbers" class="flex items-center gap-1">
              <button class="px-3 py-2 bg-egyptian text-white rounded-lg text-sm">1</button>
              <button class="px-3 py-2 hover:bg-vanilla/30 rounded-lg text-sm text-egyptian">2</button>
              <button class="px-3 py-2 hover:bg-vanilla/30 rounded-lg text-sm text-egyptian">3</button>
            </div>
            
            <button 
              id="next-btn"
              class="px-4 py-2 bg-white border border-egyptian/10 rounded-lg text-sm text-egyptian hover:border-egyptian/30 transition-colors"
            >
              Next ›
            </button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script define:vars={{ articles, ITEMS_PER_PAGE }}>
  let currentPage = 1;
  let filteredArticles = [...articles];
  let currentSort = 'date-desc';

  const searchInput = document.getElementById('search-input');
  const sortSelect = document.getElementById('sort-select');
  const articlesList = document.getElementById('articles-list');
  const noResults = document.getElementById('no-results');
  const paginationInfo = document.getElementById('pagination-info');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const pageNumbers = document.getElementById('page-numbers');

  function renderArticles() {
    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    const end = start + ITEMS_PER_PAGE;
    const pageArticles = filteredArticles.slice(start, end);
    
    if (pageArticles.length === 0) {
      articlesList.innerHTML = '';
      noResults.classList.remove('hidden');
    } else {
      noResults.classList.add('hidden');
      articlesList.innerHTML = pageArticles.map((article, index) => `
        <a 
          href="#" 
          class="block md:grid md:grid-cols-12 gap-4 px-6 py-4 border-b border-egyptian/5 hover:bg-vanilla/20 transition-colors group"
        >
          <div class="col-span-6 flex items-start gap-3">
            <svg class="w-5 h-5 text-egyptian/40 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span class="font-medium text-egyptian group-hover:text-mauve transition-colors line-clamp-2">
              ${article.title}
            </span>
          </div>
          <div class="col-span-2 md:col-span-2 mt-2 md:mt-0">
            <span class="inline-block px-2 py-1 text-xs font-semibold rounded-full ${
              article.color === 'egyptian' ? 'bg-egyptian/10 text-egyptian' :
              article.color === 'mauve' ? 'bg-mauve/10 text-mauve' :
              article.color === 'canary' ? 'bg-canary/30 text-egyptian' :
              'bg-vanilla text-egyptian/70'
            }">
              ${article.category}
            </span>
          </div>
          <div class="col-span-2 md:col-span-2 mt-2 md:mt-0 text-sm text-egyptian/50">
            ${new Date(article.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </div>
          <div class="col-span-2 md:col-span-2 mt-2 md:mt-0 text-sm text-egyptian/50 flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            ${article.author}
          </div>
        </a>
      `).join('');
    }

    updatePagination();
  }

  function updatePagination() {
    const totalPages = Math.ceil(filteredArticles.length / ITEMS_PER_PAGE);
    const start = (currentPage - 1) * ITEMS_PER_PAGE + 1;
    const end = Math.min(currentPage * ITEMS_PER_PAGE, filteredArticles.length);
    
    paginationInfo.textContent = `Showing ${start}-${end} of ${filteredArticles.length}`;
    
    prevBtn.disabled = currentPage === 1;
    prevBtn.classList.toggle('cursor-not-allowed', currentPage === 1);
    prevBtn.classList.toggle('text-egyptian/50', currentPage === 1);
    prevBtn.classList.toggle('text-egyptian', currentPage > 1);
    
    nextBtn.disabled = currentPage === totalPages || totalPages === 0;
    nextBtn.classList.toggle('cursor-not-allowed', currentPage === totalPages || totalPages === 0);
    nextBtn.classList.toggle('text-egyptian/50', currentPage === totalPages || totalPages === 0);
    nextBtn.classList.toggle('text-egyptian', currentPage < totalPages);

    // Render page numbers
    let pagesHtml = '';
    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
        pagesHtml += `<button class="px-3 py-2 rounded-lg text-sm transition-colors ${i === currentPage ? 'bg-egyptian text-white' : 'text-egyptian hover:bg-vanilla/30'}" data-page="${i}">${i}</button>`;
      } else if (i === currentPage - 2 || i === currentPage + 2) {
        pagesHtml += `<span class="px-2 text-egyptian/30">...</span>`;
      }
    }
    pageNumbers.innerHTML = pagesHtml;

    // Add click handlers
    pageNumbers.querySelectorAll('button[data-page]').forEach(btn => {
      btn.addEventListener('click', () => {
        currentPage = parseInt(btn.dataset.page);
        renderArticles();
      });
    });
  }

  function filterAndSort() {
    const searchTerm = searchInput.value.toLowerCase();
    
    filteredArticles = articles.filter(article => {
      return article.title.toLowerCase().includes(searchTerm) ||
             article.category.toLowerCase().includes(searchTerm) ||
             article.author.toLowerCase().includes(searchTerm);
    });

    // Sort
    filteredArticles.sort((a, b) => {
      switch (currentSort) {
        case 'date-desc':
          return new Date(b.date).getTime() - new Date(a.date).getTime();
        case 'date-asc':
          return new Date(a.date).getTime() - new Date(b.date).getTime();
        case 'title-asc':
          return a.title.localeCompare(b.title);
        case 'title-desc':
          return b.title.localeCompare(a.title);
        default:
          return 0;
      }
    });

    currentPage = 1;
    renderArticles();
  }

  searchInput.addEventListener('input', filterAndSort);
  sortSelect.addEventListener('change', (e) => {
    currentSort = e.target.value;
    filterAndSort();
  });

  prevBtn.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderArticles();
    }
  });

  nextBtn.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredArticles.length / ITEMS_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage++;
      renderArticles();
    }
  });

  // Initial render
  renderArticles();
</script>
