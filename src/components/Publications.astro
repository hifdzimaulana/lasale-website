---
const articles = [
  {
    category: "Legal Analysis",
    title: "Understanding Procedural Fairness in Indonesian Civil Litigation",
    author: "Ahmad Pratama, 2024",
    readTime: "8 min read",
    color: "egyptian",
    date: "2024-12-15"
  },
  {
    category: "Moot Court Guide",
    title: "Mastering Oral Advocacy: Tips from Competition Veterans",
    author: "Sarah Indonesia, 2024",
    readTime: "6 min read",
    color: "mauve",
    date: "2024-11-20"
  },
  {
    category: "Research Paper",
    title: "The Evolution of Criminal Procedure Code in Indonesia",
    author: "Budi Santoso, 2023",
    readTime: "12 min read",
    color: "canary",
    date: "2023-08-10"
  },
  {
    category: "Case Study",
    title: "Landmark Supreme Court Rulings: A Comprehensive Review",
    author: "Diana Chen, 2023",
    readTime: "10 min read",
    color: "vanilla",
    date: "2023-05-22"
  }
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const recentArticles = articles.slice(0, 2);
---

<section id="publications" class="py-12 md:py-20 bg-cornsilk relative overflow-hidden">
  <!-- Wave Divider Top -->
  <div class="absolute top-0 left-0 right-0 h-16 -translate-y-[99%]">
    <svg class="w-full h-full" viewBox="0 0 1440 100" preserveAspectRatio="none">
      <path d="M0 100 C 360 50 720 0 1440 100 L 1440 0 L 0 0 Z" fill="#F8F8AA"/>
    </svg>
  </div>

  <!-- Background Elements -->
  <div class="absolute top-1/3 left-10 w-64 h-64 bg-vanilla/50 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/3 right-10 w-48 h-48 bg-canary/20 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 fade-in-section">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-vanilla rounded-full mb-4">
        <span class="w-1.5 h-1.5 bg-egyptian rounded-full"></span>
        <span class="text-egyptian font-medium text-sm">Knowledge Sharing</span>
      </div>
      
      <h2 class="fluid-h2 font-bold text-egyptian mb-4">
        <span class="font-script text-5xl md:text-6xl text-mauve">P</span>ublications
      </h2>
      
      <p class="text-egyptian/70 max-w-2xl mx-auto fluid-body">
        Insights, research, and analysis from our members on procedural law, litigation strategies, and the evolving landscape of Indonesian legal practice.
      </p>
    </div>

    <!-- Recent Articles Grid -->
    <div class="mb-8">
      <p class="flex items-center gap-2 text-sm text-egyptian/60 font-medium pl-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Recent Publications
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-6 lg:gap-8 mb-12">
      {recentArticles.map((article, index) => (
        <div 
          class="fade-in-section group bg-white rounded-2xl p-6 lg:p-8 border border-egyptian/10 hover:border-egyptian/30 hover:shadow-xl hover:shadow-egyptian/10 transition-all duration-300 hover:-translate-y-1"
          style={`animation-delay: ${index * 0.1}s;`}
        >
          <!-- Category Tag -->
          <div class="inline-flex items-center gap-2 mb-4">
            <span class={`px-3 py-1 text-xs font-semibold rounded-full ${
              article.color === 'egyptian' ? 'bg-egyptian/10 text-egyptian' :
              article.color === 'mauve' ? 'bg-mauve/10 text-mauve' :
              article.color === 'canary' ? 'bg-canary/30 text-egyptian' :
              'bg-vanilla text-egyptian/70'
            }`}>
              {article.category}
            </span>
          </div>

          <!-- Title -->
          <h3 class="font-emphasis text-xl font-bold text-egyptian mb-3 group-hover:text-mauve transition-colors line-clamp-2">
            {article.title}
          </h3>

          <!-- Meta -->
          <div class="flex items-center justify-between text-sm text-egyptian/50">
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              {article.author}
            </span>
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {article.readTime}
            </span>
          </div>

          <!-- Read More -->
          <div class="mt-4 pt-4 border-t border-egyptian/5">
            <a href="#" class="inline-flex items-center text-canary font-medium text-sm hover:text-mauve transition-colors group-hover:gap-2 gap-1">
              Read Article
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- View All Button -->
    <div class="text-center">
      <a 
        href="/publications"
        class="inline-flex items-center px-8 py-4 bg-egyptian text-cornsilk font-emphasis font-semibold rounded-xl hover:bg-mauve transition-all duration-300"
      >
        View All Publications
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Wave Divider Bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-16 -translate-y-[1px]">
    <svg class="w-full h-full" viewBox="0 0 1440 100" preserveAspectRatio="none">
      <path d="M0 0 C 360 50 720 100 1440 0 L 1440 100 L 0 100 Z" fill="#1B3598"/>
    </svg>
  </div>
</section>