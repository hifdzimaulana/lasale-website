---
---

<section id="contact" class="py-12 md:py-20 bg-egyptian relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 opacity-10">
    <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
      <defs>
        <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
          <path d="M 10 0 L 0 0 0 10" fill="none" stroke="#FFF9E1" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100" height="100" fill="url(#grid)" />
    </svg>
  </div>
  
  <div class="absolute top-20 right-20 w-32 h-32 bg-canary/20 rounded-full blur-2xl animate-float"></div>
  <div class="absolute bottom-20 left-20 w-48 h-48 bg-mauve/10 rounded-full blur-2xl animate-float" style="animation-delay: 1.5s;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
      <!-- Left: Content -->
      <div class="fade-in-section">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-canary/20 rounded-full mb-4">
          <span class="w-1.5 h-1.5 bg-canary rounded-full"></span>
          <span class="text-canary font-medium text-sm">Contact Us</span>
        </div>
        
        <h2 class="fluid-h2 font-bold text-cornsilk mb-6">
          <span class="font-script text-5xl md:text-6xl text-canary">G</span>et In Touch
        </h2>
        
        <p class="text-cornsilk/70 fluid-body mb-8">
          Have questions about our programs, events, or want to collaborate? We'd love to hear from you.
        </p>

        <!-- Contact Options -->
        <div class="space-y-4">
          <a href="mailto:eksternal.lasalefhui@gmail.com" class="flex items-center gap-4 p-4 bg-white/5 rounded-xl border border-white/10 hover:border-canary/30 transition-colors cursor-pointer group">
            <div class="w-12 h-12 bg-canary/20 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-canary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-cornsilk font-semibold">Email Us</p>
              <p class="text-cornsilk/60 text-sm group-hover:text-canary transition-colors">eksternal.lasalefhui@gmail.com</p>
            </div>
          </a>

          <a href="https://maps.app.goo.gl/EqiZkcZ7aSTmsHS98" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-4 bg-white/5 rounded-xl border border-white/10 hover:border-canary/30 transition-colors cursor-pointer group">
            <div class="w-12 h-12 bg-canary/20 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-canary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-cornsilk font-semibold">Visit Us</p>
              <p class="text-cornsilk/60 text-sm group-hover:text-canary transition-colors">FHUI, Universitas Indonesia, Depok</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="fade-in-section" style="animation-delay: 0.2s;">
        <form class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 lg:p-8 border border-white/10">
          <h3 class="font-emphasis text-2xl font-bold text-cornsilk mb-6">Send Us a Message</h3>
          
          <div class="space-y-4">
            <div>
              <label for="name" class="block text-cornsilk/80 text-sm font-medium mb-2">Full Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-cornsilk placeholder-cornsilk/40 focus:outline-none focus:border-canary focus:ring-1 focus:ring-canary transition-colors"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="email" class="block text-cornsilk/80 text-sm font-medium mb-2">Email Address</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-cornsilk placeholder-cornsilk/40 focus:outline-none focus:border-canary focus:ring-1 focus:ring-canary transition-colors"
                placeholder="your@email.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-cornsilk/80 text-sm font-medium mb-2">Subject</label>
              <select 
                id="subject" 
                name="subject" 
                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-cornsilk focus:outline-none focus:border-canary focus:ring-1 focus:ring-canary transition-colors"
              >
                <option value="" class="text-egyptian">Select a topic</option>
                <option value="general" class="text-egyptian">General Inquiry</option>
                <option value="partnership" class="text-egyptian">Partnership</option>
                <option value="events" class="text-egyptian">Events & Programs</option>
                <option value="media" class="text-egyptian">Media & Press</option>
                <option value="other" class="text-egyptian">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-cornsilk/80 text-sm font-medium mb-2">Message</label>
              <textarea 
                id="message" 
                name="message" 
                rows="4" 
                required
                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-cornsilk placeholder-cornsilk/40 focus:outline-none focus:border-canary focus:ring-1 focus:ring-canary transition-colors resize-none"
                placeholder="Tell us how we can help..."
              ></textarea>
            </div>

            <button 
              type="submit" 
              class="w-full py-4 bg-canary text-egyptian font-emphasis font-semibold text-lg rounded-xl hover:bg-cornsilk hover:shadow-lg transition-all duration-300"
            >
              Send Message
            </button>

            <div class="relative flex items-center py-4">
              <div class="flex-grow border-t border-white/20"></div>
              <span class="flex-shrink-0 mx-4 text-cornsilk/40 text-sm">or</span>
              <div class="flex-grow border-t border-white/20"></div>
            </div>

            <a 
              href="https://wa.me/6285715698812"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full py-4 bg-green-500 text-white font-emphasis font-semibold text-lg rounded-xl hover:bg-green-600 hover:shadow-lg transition-all duration-300 flex items-center justify-center gap-2"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.521.151-.172.2-.296.3-.493.099-.198.05-.371-.025-.521-.075-.148-.669-1.611-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Contact via WhatsApp
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>