---
---

<section id="about" class="py-20 md:py-32 bg-vanilla/30 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-canary/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 bg-mauve/10 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Content -->
      <div class="fade-in-section">
        <!-- Section Label -->
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-cornsilk rounded-full mb-4">
          <span class="w-1.5 h-1.5 bg-mauve rounded-full"></span>
          <span class="text-mauve font-medium text-sm">Who We Are</span>
        </div>

        <!-- Heading with Pinyon Script initial -->
        <h2 class="fluid-h2 font-bold text-egyptian mb-6">
          <span class="font-script text-5xl md:text-6xl text-mauve">A</span>bout LaSALe
        </h2>

        <p class="text-egyptian/70 fluid-body mb-6">
          <strong class="text-egyptian">LaSALe FHUI</strong> (Law Student Association for Legal Practice) is a dynamic student organization at the Faculty of Law, Universitas Indonesia, dedicated to excellence in procedural law and litigation.
        </p>

        <p class="text-egyptian/70 fluid-body mb-8">
          Founded on the belief that <span class="text-mauve font-semibold"> courtroom mastery is forged through practice</span>, we provide unparalleled opportunities for law students to develop their advocacy skills through moot court competitions, workshops, and collaborative learning initiatives.
        </p>

        <!-- Mission Points -->
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-canary rounded flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-4 h-4 text-egyptian" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-egyptian/80">Promote excellence in procedural law and litigation skills</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-canary rounded flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-4 h-4 text-egyptian" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-egyptian/80">Nurture future legal professionals through moot court competitions</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-canary rounded flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-4 h-4 text-egyptian" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-egyptian/80">Bridge academic theory with practical courtroom experience</p>
          </div>
        </div>
      </div>

      <!-- Image/Visual -->
      <div class="relative fade-in-section" style="animation-delay: 0.2s;">
        <div class="relative aspect-[4/5] rounded-2xl overflow-hidden">
          <!-- Stock image from Unsplash -->
          <img 
            src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=800&q=80" 
            alt="Students in a law lecture hall"
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-br from-egyptian/70 via-egyptian/50 to-mauve/60"></div>
          
          <!-- Overlay with content -->
          <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center">
            <div class="w-20 h-20 bg-canary/20 rounded-full flex items-center justify-center mb-6 backdrop-blur-sm">
              <svg class="w-10 h-10 text-canary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
              </svg>
            </div>
            <h3 class="font-emphasis text-2xl text-cornsilk mb-2">Excellence in Action</h3>
            <p class="text-cornsilk/70 max-w-xs">Building the future of Indonesian legal practice, one case at a time.</p>
          </div>

          <!-- Decorative elements -->
          <div class="absolute top-4 right-4 w-16 h-16 bg-canary/30 star-four-points animate-float"></div>
          <div class="absolute bottom-8 left-4 w-12 h-12 bg-vanilla/40 star-four-points animate-float" style="animation-delay: 1s;"></div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-6 -right-6 bg-cornsilk rounded-xl p-4 shadow-xl border border-egyptian/10">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-canary rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-egyptian" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-egyptian font-semibold text-sm">Established</p>
              <p class="text-egyptian/60 text-xs">Since 2015</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>