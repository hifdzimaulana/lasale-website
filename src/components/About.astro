---
---

<section id="about" class="py-12 md:py-20 bg-vanilla/30 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-canary/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 bg-mauve/10 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-5 gap-12 lg:gap-20 items-start">
      <!-- Content -->
      <div class="lg:col-span-3 fade-in-section">
        <!-- Section Label -->
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-cornsilk rounded-full mb-4">
          <span class="w-1.5 h-1.5 bg-mauve rounded-full"></span>
          <span class="text-mauve font-medium text-sm">Who We Are</span>
        </div>

        <!-- Heading with Pinyon Script initial -->
        <h2 class="fluid-h2 font-bold text-egyptian mb-6">
          <span class="font-script text-5xl md:text-6xl text-mauve">A</span>bout LaSALe
        </h2>

        <p class="text-egyptian/70 fluid-body mb-6">
          <strong class="text-egyptian">LaSALe FHUI</strong> (Law Student Association for Legal Practice) is a dynamic student organization at the Faculty of Law, Universitas Indonesia, dedicated to excellence in procedural law and litigation.
        </p>

        <p class="text-egyptian/70 fluid-body mb-8">
          Founded on the belief that <span class="text-mauve font-semibold"> courtroom mastery is forged through practice</span>, we provide unparalleled opportunities for law students to develop their advocacy skills through moot court competitions, workshops, and collaborative learning initiatives.
        </p>

        <!-- Mission Points -->
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-canary rounded flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-4 h-4 text-egyptian" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-egyptian/80">Promote excellence in procedural law and litigation skills</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-canary rounded flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-4 h-4 text-egyptian" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-egyptian/80">Nurture future legal professionals through moot court competitions</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-canary rounded flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-4 h-4 text-egyptian" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-egyptian/80">Bridge academic theory with practical courtroom experience</p>
          </div>
        </div>
      </div>

      <!-- Preface from Executive Director -->
      <div class="lg:col-span-2 relative fade-in-section" style="animation-delay: 0.2s;">
        <div class="flex flex-col gap-6">
          <!-- Creative Floating Tilted Photo with Scattered Board Members -->
          <div class="relative mx-auto md:mx-0 w-full min-h-[320px] flex items-center justify-center">
            <!-- Scattered Board Members Polaroids (Background) -->
            <div class="absolute inset-0 flex items-center justify-center">
              <!-- Board Member 1 - Top Left -->
              <div class="absolute top-0 left-4 md:left-8 rotate-[-8deg] z-0">
                <div class="bg-white p-1.5 pb-6 rounded-sm shadow-lg">
                  <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=200&q=80" alt="Board Member" class="w-24 h-28 object-cover rounded-sm" />
                </div>
              </div>
              <!-- Board Member 2 - Top Right -->
              <div class="absolute top-2 right-2 md:right-4 rotate-[6deg] z-0">
                <div class="bg-white p-1.5 pb-6 rounded-sm shadow-lg">
                  <img src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=200&q=80" alt="Board Member" class="w-28 h-32 object-cover rounded-sm" />
                </div>
              </div>
              <!-- Board Member 3 - Left -->
              <div class="absolute left-0 md:left-4 top-1/2 -translate-y-1/2 rotate-[-4deg] z-0">
                <div class="bg-white p-1.5 pb-6 rounded-sm shadow-lg">
                  <img src="https://images.unsplash.com/photo-1577219491135-391c6f2ad1a3?w=200&q=80" alt="Board Member" class="w-26 h-30 object-cover rounded-sm" />
                </div>
              </div>
              <!-- Board Member 4 - Right -->
              <div class="absolute right-4 md:right-12 top-1/2 -translate-y-1/2 rotate-[5deg] z-0">
                <div class="bg-white p-1.5 pb-6 rounded-sm shadow-lg">
                  <img src="https://images.unsplash.com/photo-1580489944761-15a19d654956?w=200&q=80" alt="Board Member" class="w-24 h-28 object-cover rounded-sm" />
                </div>
              </div>
              <!-- Board Member 5 - Bottom Left -->
              <div class="absolute bottom-2 left-8 md:left-12 rotate-[-3deg] z-0">
                <div class="bg-white p-1.5 pb-6 rounded-sm shadow-lg">
                  <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&q=80" alt="Board Member" class="w-26 h-30 object-cover rounded-sm" />
                </div>
              </div>
            </div>

            <!-- Executive Director Photo (Front) -->
            <div class="relative group z-10">
              <!-- Decorative behind elements -->
              <div class="absolute -inset-3 bg-canary/30 rounded-xl -z-10 rotate-3 group-hover:rotate-2 transition-transform duration-300"></div>
              <div class="absolute -inset-2 bg-mauve/20 rounded-lg -z-20 -rotate-2 group-hover:rotate-1 transition-transform duration-300"></div>
              
              <!-- Polaroid frame -->
              <div class="bg-white p-2 pb-8 rounded-sm shadow-xl rotate-2 group-hover:rotate-0 transition-transform duration-300">
                <div class="w-40 h-48 md:w-44 md:h-52 overflow-hidden">
                  <img 
                    src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&q=80" 
                    alt="Ghania Latifa Putri Rizni - Executive Director" 
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>
              
              <!-- Floating four-pointed star SVG -->
              <div class="absolute -bottom-2 -right-2 w-8 h-8 animate-pulse">
                <svg viewBox="0 0 122.88 122.88" class="w-full h-full fill-mauve">
                  <path d="M62.43,122.88h-1.98c0-16.15-6.04-30.27-18.11-42.34C30.27,68.47,16.16,62.43,0,62.43v-1.98 c16.16,0,30.27-6.04,42.34-18.14C54.41,30.21,60.45,16.1,60.45,0h1.98c0,16.15,6.04,30.27,18.11,42.34 c12.07,12.07,26.18,18.11,42.34,18.11v1.98c-16.15,0-30.27,6.04-42.34,18.11C68.47,92.61,62.43,106.72,62.43,122.88L62.43,122.88z"/>
                </svg>
              </div>
            </div>
            <p class="absolute bottom-0 text-center text-xs text-egyptian/60 mt-3 font-emphasis rotate-2">Executive Director</p>
          </div>

          <!-- Preface Content -->
          <div class="text-center md:text-left">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-cornsilk rounded-full mb-3">
              <span class="w-1.5 h-1.5 bg-mauve rounded-full"></span>
              <span class="text-mauve font-medium text-xs">Preface</span>
            </div>
            
            <h3 class="font-emphasis text-lg md:text-xl text-egyptian mb-3">
              A Message from Our Executive Director
            </h3>
            
            <p class="text-egyptian/70 text-sm leading-relaxed mb-3">
              Welcome to LaSALe FHUI! As your Executive Director, I am honored to lead an organization dedicated to shaping the future of Indonesian legal practice.
            </p>
            
            <p class="text-egyptian/70 text-sm leading-relaxed mb-3">
              Through moot court competitions, intensive workshops, and collaborative learning initiatives, we bridge the gap between academic theory and real-world litigation.
            </p>

            <div class="pt-2">
              <p class="text-egyptian font-semibold text-sm">Ghania Latifa Putri Rizni</p>
              <p class="text-mauve text-xs">Executive Director | LaSALe FHUI</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>