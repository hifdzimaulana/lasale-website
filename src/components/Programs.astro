---
const programs = [
  {
    title: "Moot Court Training",
    description: "Intensive training sessions for competition preparation, covering case analysis, written submissions, and oral advocacy.",
    image: "https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=800&q=80",
    color: "egyptian"
  },
  {
    title: "Legal Writing Workshop",
    description: "Develop persuasive legal writing skills through workshops on argumentation, citation, and professional drafting.",
    image: "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=800&q=80",
    color: "mauve"
  },
  {
    title: "Mentorship Program",
    description: "Connect with experienced alumni and legal professionals for guidance on career development and litigation skills.",
    image: "https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&q=80",
    color: "canary"
  },
  {
    title: "Client Interviewing",
    description: "Learn essential client interaction skills through simulated interviews and case intake exercises.",
    image: "https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=800&q=80",
    color: "vanilla"
  },
  {
    title: "Trial Advocacy",
    description: "Master courtroom presence and persuasive argumentation techniques for effective litigation.",
    image: "https://images.unsplash.com/photo-1505664194779-8beaceb93744?w=800&q=80",
    color: "mauve"
  },
  {
    title: "Legal Research Methods",
    description: "Advanced research techniques using legal databases and secondary sources effectively.",
    image: "https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?w=800&q=80",
    color: "egyptian"
  },
  {
    title: "Negotiation Skills",
    description: "Learn strategic negotiation tactics for settlements and dispute resolution.",
    image: "https://images.unsplash.com/photo-1551836022-d5c88ce21a5f?w=800&q=80",
    color: "canary"
  },
  {
    title: "Professional Ethics",
    description: "Understand professional responsibility and ethical obligations in legal practice.",
    image: "https://images.unsplash.com/photo-1589216532372-1c2a367900d9?w=800&q=80",
    color: "vanilla"
  }
];
---

<section id="programs" class="py-12 md:py-20 bg-vanilla/20 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-cornsilk to-transparent"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-canary/10 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 fade-in-section">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-cornsilk rounded-full mb-4">
        <span class="w-1.5 h-1.5 bg-mauve rounded-full"></span>
        <span class="text-mauve font-medium text-sm">What We Offer</span>
      </div>
      
      <h2 class="fluid-h2 font-bold text-egyptian mb-4">
        <span class="font-script text-5xl md:text-6xl text-mauve">P</span>rograms & Activities
      </h2>
      
      <p class="text-egyptian/70 max-w-2xl mx-auto fluid-body">
        Our comprehensive programs are designed to develop well-rounded legal professionals equipped for the challenges of modern litigation practice.
      </p>
    </div>

    <!-- Videotron Style Carousel -->
    <div class="relative" id="programs-carousel">
      <!-- Progress Dots -->
      <div class="flex justify-center gap-2 mb-6">
        {programs.map((_, index) => (
          <div class="progress-dot w-12 h-1.5 rounded-full bg-black/50 overflow-hidden cursor-pointer" data-index={index}>
            <div class="progress-bar h-full bg-canary rounded-full" style="width: 0%"></div>
          </div>
        ))}
      </div>

      <!-- Videotron Screen -->
      <div class="relative max-w-4xl mx-auto">
        <div class="relative rounded-2xl shadow-2xl overflow-hidden">
          <div class="relative aspect-video">
            <!-- Carousel Track -->
            <div class="flex transition-transform duration-500 ease-out" id="carousel-track">
              {programs.map((program, index) => (
                <div class="w-full flex-shrink-0 relative">
                  <!-- Background Image -->
                  <div class="relative h-[420px] sm:h-[540px]">
                    <img 
                      src={program.image} 
                      alt={program.title}
                      class="w-full h-full object-cover"
                    />
                    <!-- Gradient Overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-black/30"></div>
                    
                    <!-- Content Overlay -->
                    <div class="absolute inset-0 flex flex-col justify-end p-8 sm:p-12 z-10">
                      <h3 class="font-emphasis text-2xl sm:text-3xl font-bold text-white mb-2 drop-shadow-lg">
                        {program.title}
                      </h3>
                      <p class="text-base sm:text-lg text-white/90 leading-relaxed max-w-xl drop-shadow-md">
                        {program.description}
                      </p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Left Arrow -->
      <button 
        id="prev-btn"
        class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-30 w-12 h-12 bg-white/90 rounded-full shadow-xl flex items-center justify-center text-egyptian hover:bg-white transition-colors"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      
      <!-- Right Arrow -->
      <button 
        id="next-btn"
        class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-30 w-12 h-12 bg-white/90 rounded-full shadow-xl flex items-center justify-center text-egyptian hover:bg-white transition-colors"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('carousel-track');
  const progressDots = document.querySelectorAll('.progress-dot');
  const progressBars = document.querySelectorAll('.progress-bar');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const totalSlides = progressDots.length;
  
  let currentIndex = 0;
  let autoAdvanceInterval;
  let progressInterval;
  const autoAdvanceTime = 5000;
  const progressDuration = 100;

  function updateCarousel() {
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
    
    progressBars.forEach((bar, i) => {
      bar.style.width = i === currentIndex ? '100%' : '0%';
    });

    progressDots.forEach((dot, i) => {
      dot.style.opacity = i === currentIndex ? '1' : '0.5';
    });
  }

  function nextSlide() {
    currentIndex = (currentIndex + 1) % totalSlides;
    updateCarousel();
    resetAutoAdvance();
  }

  function prevSlide() {
    currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
    updateCarousel();
    resetAutoAdvance();
  }

  function startProgressAnimation() {
    let progress = 0;
    progressInterval = setInterval(() => {
      progress += (progressDuration / autoAdvanceTime) * 100;
      if (progress > 100) progress = 100;
      if (progressBars[currentIndex]) {
        progressBars[currentIndex].style.width = progress + '%';
      }
    }, progressDuration);
  }

  function resetAutoAdvance() {
    clearInterval(autoAdvanceInterval);
    clearInterval(progressInterval);
    
    progressBars.forEach(bar => bar.style.width = '0%');
    startProgressAnimation();
    
    autoAdvanceInterval = setInterval(nextSlide, autoAdvanceTime);
  }

  prevBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    prevSlide();
  });

  nextBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    nextSlide();
  });

  progressDots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      currentIndex = i;
      updateCarousel();
      resetAutoAdvance();
    });
  });

  let touchStartX = 0;
  let touchEndX = 0;
  
  const tvScreen = document.querySelector('.aspect-video');
  
  tvScreen.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  });

  tvScreen.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
  });

  function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0) {
        nextSlide();
      } else {
        prevSlide();
      }
    }
  }

  resetAutoAdvance();
</script>